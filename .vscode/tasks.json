{
  "tasks": [
    {
      "label": "Build Secure Media (mingw32-make)",
      "type": "shell",
      "command": "C:/MinGW/bin/mingw32-make.exe",
      "args": [
        "-B",
        "CXX=C:/msys64/mingw64/bin/g++.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}/secure-media-network"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "C/C++: g++.exe build active file (MSYS2)",
      "type": "cppbuild",
      "command": "C:/msys64/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-std=c++17",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ],
  "version": "2.0.0"
}
